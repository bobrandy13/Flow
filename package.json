{
  "name": "flow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --parallel --filter ./apps/web --filter ./apps/api dev",
    "dev:web": "pnpm --filter @flow/web dev",
    "dev:api": "pnpm --filter @flow/api dev",
    "build": "pnpm -r --filter './apps/*' build",
    "lint": "pnpm -r --filter './apps/*' --filter './packages/*' lint",
    "typecheck": "pnpm -r --filter './apps/*' --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './apps/*' --filter './packages/*' test",
    "test:e2e": "pnpm --filter @flow/web test:e2e"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
